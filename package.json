{
  "name": "@pollanyan/wechat-acp-bridge",
  "version": "0.1.0",
  "description": "微信 ACP 桥接器 - 支持微信与OpenClaw、Hermes等Agent之间的通信",
  "license": "MIT",
  "author": "pollanyan",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wechat-acp-bridge": "dist/cli/commands.js"
  },
  "files": [
    "dist/**/*.js",
    "config"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:force": "tsc  --build --force --noEmit",
    "format": "prettier --check 'src/**/*.{ts,mts,cts,json,md}'",
    "format:fix": "prettier --write 'src/**/*.{ts,mts,cts,json,md}'",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "check:baseall": "npm run typecheck && npm run format && npm run lint ",
    "check:fix": "npm run format:fix && npm run lint:fix ",
    "check:jscpd": "jscpd src/",
    "check:depdupes": "node -e \"const d=require('./package.json').dependencies||{};const p=require('./package.json').devDependencies||{};const dup=Object.keys(d).filter(k=>k in p);if(dup.length){console.error('包同时存在于 dependencies 和 devDependencies:',dup.join(', '));process.exit(1)}else console.log('无重复包引入')\"",
    "check:depcheck": "depcheck",
    "check:audit": "npm audit --audit-level=high",
    "check:extall": "npm run check:jscpd && npm run check:depdupes && npm run check:depcheck && npm run check:audit",
    "check:all": "npm run check:baseall && npm run check:extall",
    "test:dev": "vitest --watch",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist",
    "build": "tsc && chmod +x dist/cli/commands.js",
    "build:clean": "npm run clean && npm run build",
    "run-dev": "ts-node src/cli/commands.ts run",
    "run": "node dist/cli/commands.js run",
    "service:install": "node dist/cli/commands.js install",
    "service:uninstall": "node dist/cli/commands.js uninstall",
    "prepare": "npx simple-git-hooks || true",
    "prepack": "npm run check:all && npm run test && npm run build:clean"
  },
  "engines": {
    "node": ">=22"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check:all && npm run test",
    "commit-msg": "npx commitlint --edit $1"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.1",
    "axios": "^1.16.1",
    "commander": "^14.0.3",
    "inquirer": "^13.4.3",
    "qrcode-terminal": "^0.12.0",
    "winston": "^3.19.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.8.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jscpd": "^4.2.3",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
